    <xs:complexType name="ESRDMD_Envelope" sawsdl:modelReference="http://iec.ch/TC57/CIM100#ESRDMD_Envelope">
        <xs:annotation>
            <xs:documentation>The envelope entity is a non-CIM object used in an energy data space environment to serve
                as a central top-level entity connecting the MarketDocumentHeader (energy data space specific context
